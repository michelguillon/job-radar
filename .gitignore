# Secrets — never commit
.env

# Python
__pycache__/
.pytest_cache/
*.py[cod]

# JSONL data anywhere
*.jsonl

# Corpus data: ignore all contents, keep the directory skeleton (.gitkeep)
corpus/**/*
!corpus/**/
!corpus/**/.gitkeep

# Pipeline cursors (mutable local state; covered by corpus/**/* above, listed
# explicitly for clarity): incremental collection + daily digest.
corpus/.last_collected_*
corpus/.digest_last_run

# cv-tailor run links (personal corpus data, like activity_log.jsonl; covered by
# *.jsonl + corpus/**/* above, listed explicitly per job_radar_SPEC §11.3).
corpus/cv_tailor_links.jsonl

# SQLite interactive-state store + WAL/SHM sidecars (Phase 6.5, SPEC_DB_MIGRATION).
# Personal corpus data like the JSONL state files; covered by corpus/**/* above,
# listed explicitly for clarity.
corpus/job_radar.db
corpus/job_radar.db-wal
corpus/job_radar.db-shm

# Personal-data planning doc — real role URLs, job IDs, server paths, corpus
# migration details. Lives locally + travels by scp like the corpus; never commit
# (the repo is a public portfolio). The deploy runbook is self-contained and does
# not depend on this file being present on the server.
docs/BACKLOG_COMPANY_UNIVERSE.md

# Working prompt scratch (DEPLOY_PROMPT / PHASE*_PROMPT). Kept locally, never tracked.
docs/*PROMPT*

# Temporary build docs — feature PLANs, handoffs, scratch. Live here, never in docs/
# (CLAUDE.md "Temporary build docs" convention). Durable decisions get migrated out first.
tmp/

# Local corpus-review exports (cli.analyse / report dumps). Corpus-derived personal data
# like the corpus itself — generated on demand, never committed (the repo is public).
exports/
