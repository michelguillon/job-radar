# Copy to .env and fill in. Never commit .env.

# --- Pipeline (collect / label / score) -------------------------------------------------
# Only needed if you run the labelling/scoring pipeline (cli.label, cli.score, …) — the
# served UI (api + frontend) makes NO Anthropic calls, so a pure deployment can leave this
# blank. Required for any Batch-API labelling run.
ANTHROPIC_API_KEY=your_key_here

# --- Interactive UI: owner write capability (api/security.py, SPEC §10.8) ---------------
# Owner unlock secret AND the HMAC signing key for the jr_write cookie. UNSET = read-only
# deployment: every write endpoint 403s and the UI hides its write controls (fail-closed).
# Set a strong random value to enable owner writes (status/notes/outcome/flags) from the
# browser via the unlock dialog. Generate one with e.g.  openssl rand -hex 32
JR_WRITE_KEY=

# Send the jr_write cookie with the Secure flag (HTTPS-only). Set `true` in production —
# the public URL is HTTPS via Cloudflare. Leave blank/false for plain-http localhost dev.
COOKIE_SECURE=

# --- cv-tailor integration: Phase 3 callback (api/routers/cv_tailor.py, SPEC §11.3) ------
# Shared secret for cv-tailor → Job Radar machine-to-machine callback. cv-tailor sends it as
# an `Authorization: Bearer <key>` header on POST /api/cv-tailor-results; Job Radar accepts
# that OR the owner cookie. Separate from JR_WRITE_KEY. UNSET = Bearer path closed (the
# manual owner-cookie path still works). Generate with e.g.  openssl rand -hex 32
CV_TAILOR_SERVICE_KEY=

# --- Observability: Langfuse tracing (cli/telemetry.py, SPEC_LANGFUSE_INSTRUMENTATION) ---
# Opt-in pipeline tracing for the Batch-API extraction + scoring runs. UNSET = no tracing
# (every telemetry call is a clean no-op — this is the default, and how the test suite runs).
# Use the JOB-RADAR project keys (NOT cv-tailor's) — shared keys land traces in the wrong
# project's dashboard. No quotes around values (some parsers keep the quotes, invalidating the
# key). LANGFUSE_BASE_URL must be the INTERNAL container URL — a container cannot hairpin to
# its own public Cloudflare URL (requests time out). e.g. http://langfuse-langfuse-web-1:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
